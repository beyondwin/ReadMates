{
  "name": "readmates-front",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:budget": "tsx scripts/build-budget.ts",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "lighthouse:diagnose": "tsx scripts/lighthouse-diagnostic.ts",
    "lighthouse:preview": "tsx scripts/lighthouse-preview.ts",
    "performance:budget": "pnpm build && pnpm build:budget",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:ct": "playwright test --config=playwright-ct.config.ts",
    "test:ct:docker": "tsx scripts/run-ct-docker.ts",
    "test:ct:update": "playwright test --config=playwright-ct.config.ts --update-snapshots",
    "test:ct:update:docker": "tsx scripts/run-ct-docker.ts --update",
    "test:watch": "vitest",
    "zod:export-fixtures": "tsx scripts/export-zod-fixtures.ts"
  },
  "dependencies": {
    "@readmates/design-system": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/experimental-ct-react": "1.61.1",
    "@playwright/test": "1.61.1",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "lighthouse": "^13.4.0",
    "tslib": "^2.8.1",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.64.0",
    "vite": "8.1.5",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
