    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
