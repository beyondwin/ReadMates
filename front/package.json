{
  "name": "readmates-front",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "lighthouse:diagnose": "tsx scripts/lighthouse-diagnostic.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:ct": "playwright test --config=playwright-ct.config.ts",
    "test:ct:update": "playwright test --config=playwright-ct.config.ts --update-snapshots",
    "test:ct:update:docker": "docker run --rm --ipc=host -e CI=true -v \"$PWD/..\":/work -w /work/front mcr.microsoft.com/playwright:v1.60.0-jammy /bin/sh -lc 'corepack enable && pnpm install --frozen-lockfile=false && pnpm exec playwright test --config=playwright-ct.config.ts --update-snapshots'",
    "test:watch": "vitest",
    "zod:export-fixtures": "tsx scripts/export-zod-fixtures.ts"
  },
  "dependencies": {
    "@readmates/design-system": "workspace:*",
    "@tanstack/react-query": "^5.100.10",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/experimental-ct-react": "^1.54.1",
    "@playwright/test": "^1.54.1",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^26.1.0",
    "lighthouse": "^13.4.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.0",
    "vite": "8.0.16",
    "vitest": "^4.1.0",
    "zod": "^4.4.3"
  }
}
