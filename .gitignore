# =============================================================================
# OS / filesystem cruft
# =============================================================================
.DS_Store
**/.DS_Store
Thumbs.db
desktop.ini
._*

# =============================================================================
# IDE / editor
# =============================================================================
.idea/
*.iml
.vscode/
.fleet/
.cursor/
*.swp
*.bak
*.orig
*.rej

# =============================================================================
# Secrets and credentials (never commit)
# =============================================================================
.env
.env.*
*.env
!.env.example
!.env.*.example
!*.env.example
.dev.vars
.dev.vars.*
*.pem
*.key

# =============================================================================
# JVM / Gradle (root-level; submodules have their own .gitignore)
# =============================================================================
/.gradle/
*.hprof
hs_err_pid*
replay_pid*

# =============================================================================
# Node / pnpm / front-end build artifacts (root-level safety net)
# =============================================================================
node_modules/
*.tsbuildinfo
dist/
.vite/
.turbo/

# =============================================================================
# Test / e2e artifacts (root-level safety net; front/ has its own too)
# =============================================================================
coverage/
test-results/
playwright-report/
# Playwright component-test build cache and dockerized pnpm store
front/playwright/.cache/
.pnpm-store/

# =============================================================================
# Logs, PIDs, runtime artifacts
# =============================================================================
*.log
*.pid

# =============================================================================
# Local databases and exports
# =============================================================================
*.db
*.sqlite
*.sqlite3
*.sql.gz
*.dump

# =============================================================================
# Tooling caches and worktrees
# =============================================================================
.worktrees/
.tmp/
.gstack/
.playwright-cli/
.playwright-mcp/
.wrangler
.cloudflare
.vercel
.superpowers/
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/commands/**
.orchestrator/
.codex-orchestrator/
.waygent/
.server-config/
output/
recode

# =============================================================================
# Design system — tracked source lives under /design; ignore local exports
# =============================================================================
/design/standalone/
/design/docs/dist/
/design/system/dist/

# =============================================================================
# Deploy state (never commit live infra state)
# =============================================================================
deploy/oci/.deploy-state
deploy/oci/*.env
deploy/oci/*.state
deploy/cloudflare/.deploy-hook.env

# =============================================================================
# Docs — private working notes
# =============================================================================
docs/private/

# =============================================================================
# Local session import drafts
# =============================================================================
/readmates-session-*-import.json
/readmates-session-*-import.txt
/session-*-feedback.md
/session-*-feedback.txt

# =============================================================================
# Local-only Spring profiles
# =============================================================================
application-local.*
application-*.local.*
